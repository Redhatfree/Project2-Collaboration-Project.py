import pandas as pd
import numpy as np
import matplotlib.pyplot as plt

# 1. Data loading and preperation
# Vi laster inn data og lager 'Estimated_Hours' for simulation of virkelighetens varianse of reality
df = pd.read_csv(r"C:\Users\Rouzbeh\Desktop\python\sprint_data.csv")

# Feature Engineering: 4 hour for each point + random noise (-3 til +6 timer)
df['Estimated_Hours'] = df['Story_Points'] * 4 + np.random.randint(-3, 7, size=len(df))

# 2. Statistical calculations
mean_pts = df['Story_Points'].mean()
std_pts = df['Story_Points'].std()
limit = mean_pts + std_pts  # Definition of static risk (Outliers)

# 3. CATEGORISING (RISK LEVEL)
# Vi highlight tasks which are "CRITICAL" if they are over limit, else "STABLE"
df['Risk_Level'] = ['CRITICAL' if x > limit else 'STABLE' for x in df['Story_Points']]

# 4. MODEL-ANALYSE (CORELATION)
correlation = df['Story_Points'].corr(df['Estimated_Hours'])

# 5. MAANGEMENT REPORT (f-strings med .2f og .4f)
total_risk_hours = df[df['Risk_Level'] == 'CRITICAL']['Estimated_Hours'].sum()
num_critical = len(df[df['Risk_Level'] == 'CRITICAL'])

print("-" * 40)
print("Quantitative risk report")
print("-" * 40)
print(f"Average complexity: {mean_pts:.2f} point")
print(f"Risikogrense (1 std.avvik):  {limit:.2f} point")
print(f"Modell-pålitelighet (corr): {correlation:.4f}")
print("-" * 40)
print(f"KONKLUSJON: {num_critical} kritiske oppgaver identifisert.")
print(f"Estimated rosource usage for risk : {total_risk_hours:.1f} hour.")
print("-" * 40)

# 6. VISUALISERING
# Vi farger kritiske oppgaver røde for visuell effekt
colors = ['red' if x == 'CRITICAL' else 'skyblue' for x in df['Risk_Level']]

plt.figure(figsize=(10, 6))
plt.bar(df['Task_Name'], df['Story_Points'], color=colors)
plt.axhline(y=limit, color='black', linestyle='--', label='Risikogrense')
plt.title(f'Sprintsammensetning og Risikoprofil (Korrelasjon: {correlation:.2f})')
plt.ylabel('Story Points (Vekt)')
plt.xticks(rotation=45)
plt.legend()
plt.tight_layout()
plt.show()
print("\n" + "="*40)
print("     STETGIC RISK EVALUATION")
print("="*40)

if correlation > 0.85:
    status = "GREEN"
    message = f"Modell is complete stable ({correlation:.4f}). Story points are reliable indicators."
elif correlation > 0.60:
    status = "YELLOW"
    message = f"Model has moderate uncertainty ({correlation:.4f}). Following red parts carefully."
else:
    status = "RED"
    message = f"Notice: Low correlation ({correlation:.4f})! Plans should be evaluated."

print(f"STATUS: {status}")
print(f"RECOMMENDATION: {message}")
print("="*40)
